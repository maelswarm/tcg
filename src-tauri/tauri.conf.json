{
  "$schema": "https://schema.tauri.app/config/2.json",
  "productName": "TCG Price Tracker",
  "version": "1.0.0",
  "identifier": "com.tcgpricetracker.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build:sidecar",
    "devUrl": "http://localhost:3847",
    "frontendDist": "../site"
  },
  "app": {
    "windows": [
      {
        "title": "TCG Price Tracker",
        "url": "http://localhost:3847",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/server-sidecar"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "macOS": {
      "dmg": {
        "background": null,
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  }
}
